# frontend/.env.example
# =======================
# Copy to `.env.local` for local dev. Vite reads files named `.env.local`.
#
# In production (Railway), set VITE_API_URL to your deployed Django URL.
# Example: https://taskflow-backend.railway.app
#
# Leave blank in local dev — the Vite proxy in vite.config.js handles /api routing.
VITE_API_URL=
